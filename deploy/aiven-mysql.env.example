# =============================================================================
# Aiven for MySQL — FREE plan (no credit card required)
# https://aiven.io/free-mysql-database
#
# Sign up with GitHub/Google → Create MySQL → choose FREE plan (not paid trial)
# =============================================================================

DB_CONNECTION=mysql
DB_HOST=mysql-xxxxxxxx.a.aivencloud.com
DB_PORT=12345
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=PASTE_SERVICE_PASSWORD

# SSL (required for Aiven public endpoints)
# 1. Aiven Console → Connection information → CA certificate → Download ca.pem
# 2. Render FREE (no file upload): paste entire ca.pem content into AIVEN_CA_PEM
#    (Environment → Add variable → multiline paste)
# 3. Paid Render / local: file path instead
# AIVEN_CA_PEM=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
MYSQL_ATTR_SSL_CA=/var/www/html/storage/aiven-ca.pem

# Enable public internet access on the Aiven service so Render/Railway can connect.

# Free plan limits (approx.):
# - 1 GB RAM, 5 GB storage, dedicated VM
# - May sleep after inactivity — first query wakes it up
# - No credit card for the free MySQL product
